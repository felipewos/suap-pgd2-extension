{
  "manifest_version": 3,
  "name": "PGD2 PIT/RIT Autofill Pro (SUAP)",
  "version": "1.0.18",
  "description": "Preenche PIT/RIT no SUAP PGD2 com automação por entrega e em lote, com modo teste (trial) e licença vinculada ao usuário.",
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_popup": "ui/popup.html",
    "default_title": "SUAP PGD2 PIT/RIT"
  },
  "options_page": "ui/options.html",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*/pgd2/*",
    "https://api.proffelipewagner.com.br/api/*",
    "https://api.proffelipewagner.com.br/healthz",
    "https://api.proffelipewagner.com.br/buy*",
    "https://suap-pgd2-license-backend.felipewagner83.workers.dev/api/*",
    "https://suap-pgd2-license-backend.felipewagner83.workers.dev/healthz",
    "https://suap-pgd2-license-backend.felipewagner83.workers.dev/buy*"
  ],
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["ui/popup.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://*/pgd2/*"],
      "js": [
        "content/util.js",
        "content/suap_user.js",
        "content/auth.js",
        "content/styles_inject.js",
        "content/pit_single.js",
        "content/rit_single.js",
        "content/pit_batch.js",
        "content/rit_batch.js",
        "content/content_boot.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
